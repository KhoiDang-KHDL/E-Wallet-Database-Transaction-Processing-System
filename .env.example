APP_NAME="E-Wallet Backend"
APP_ENV=development
DEBUG=true

# Example for local Oracle XE/service:
# oracle+oracledb://username:password@localhost:1521/?service_name=XE
DATABASE_URL=oracle+oracledb://EWALLET_PROJECT:123456@localhost:1521/?service_name=orclpdb4.mshome.net

JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated user ids that can call /api/admin and /api/v1/admin endpoints.
# Your current USERS table has no role column, so backend uses this list.
ADMIN_USER_IDS=1, 2, 21
